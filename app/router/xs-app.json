{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/employeeprofile/(.*)$",
      "target": "/$1",
      "service": "employeeprofile-html5-repo",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/srv/(.*)$",
      "target": "/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^(.*)$",
      "target": "/index.html",
      "authenticationType": "xsuaa"
    }
  ],
  "csrfProtection": {
    "enable": true
  }
}
